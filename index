<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QUANTUM ANOMALY // EXTRAORDINARY v9.6</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Space+Grotesk:wght@300;400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --neon-prime: #00f3ff;
            --neon-alt: #ff0055;
            --quantum-purple: #bd00ff;
            --glass: rgba(3, 3, 8, 0.8);
            --border: rgba(189, 0, 255, 0.2);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
        }

        body, html {
            width: 100%;
            background-color: #010103;
            font-family: 'Space Grotesk', sans-serif;
            color: #fff;
            overflow-x: hidden;
            font-size: 16px;
        }

        #webgl-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            z-index: 1;
        }

        /* --- IMMERSIVE HUD OVERLAY --- */
        .hud-system {
            position: fixed;
            top: 40px;
            left: 40px;
            z-index: 100;
            font-family: 'Cinzel', serif;
            font-size: 0.8rem;
            color: #fff;
            letter-spacing: 3px;
            pointer-events: none;
            text-transform: uppercase;
        }

            .hud-system span {
                color: var(--neon-prime);
                font-weight: 900;
            }

        .scroll-progress-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: rgba(255,255,255,0.01);
            z-index: 100;
        }

        .scroll-progress-bar {
            height: 100%;
            width: 0%;
            background: linear-gradient(90deg, var(--neon-prime), var(--quantum-purple), var(--neon-alt));
        }

        /* --- LAYOUT LAYERS --- */
        .content-layer {
            position: relative;
            z-index: 2;
            pointer-events: none;
        }

        section {
            height: 100vh;
            width: 100%;
            display: flex;
            align-items: center;
            padding: 0 10%;
            position: relative;
        }

        .interactive {
            pointer-events: auto;
        }

        /* --- EXTRAORDINARY TYPOGRAPHY --- */
        .hero-text h1 {
            font-family: 'Cinzel', serif;
            font-size: 6.5rem;
            font-weight: 900;
            letter-spacing: -2px;
            line-height: 0.9;
            text-transform: uppercase;
            background: linear-gradient(135deg, #fff 20%, var(--neon-prime), var(--quantum-purple));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            filter: drop-shadow(0 0 40px rgba(189, 0, 255, 0.4));
        }

        .hero-text p {
            font-size: 1.1rem;
            letter-spacing: 12px;
            color: #585b73;
            margin-top: 25px;
            text-transform: uppercase;
        }

        /* --- PRESTIGE GLASSMORPHISM CARDS --- */
        .prestige-panel {
            background: var(--glass);
            border: 1px solid var(--border);
            padding: 50px;
            width: 100%;
            max-width: 580px;
            border-radius: 24px;
            box-shadow: 0 50px 100px rgba(0,0,0,0.8), inset 0 1px 2px rgba(255,255,255,0.05);
            backdrop-filter: blur(30px);
            -webkit-backdrop-filter: blur(30px);
            transition: border-color 0.4s ease, box-shadow 0.4s ease, transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
        }

            .prestige-panel:hover {
                border-color: var(--neon-prime);
                box-shadow: 0 50px 100px rgba(0, 243, 255, 0.1);
                transform: translateY(-8px);
            }

            .prestige-panel h2 {
                font-family: 'Cinzel', serif;
                font-size: 2rem;
                color: #fff;
                margin-bottom: 20px;
                letter-spacing: 2px;
            }

            .prestige-panel p {
                color: #a1a4bf;
                font-size: 1.05rem;
                line-height: 1.8;
                margin-bottom: 35px;
                font-weight: 300;
            }

        /* --- CONTROLLER BUTTONS --- */
        .prestige-btn {
            display: inline-block;
            padding: 18px 45px;
            border-radius: 40px;
            background: linear-gradient(90deg, var(--quantum-purple), var(--neon-alt));
            color: #fff;
            font-family: 'Space Grotesk', sans-serif;
            font-weight: 700;
            text-decoration: none;
            font-size: 0.85rem;
            letter-spacing: 3px;
            text-transform: uppercase;
            box-shadow: 0 15px 30px rgba(234, 0, 255, 0.3);
            cursor: pointer;
            border: none;
            transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        }

            .prestige-btn:hover {
                transform: scale(1.04);
                box-shadow: 0 20px 40px rgba(234, 0, 255, 0.5), 0 0 20px var(--neon-prime);
            }

        /* --- MASS FIELD CONTROLLERS --- */
        .slider-group {
            margin-bottom: 30px;
        }

        .slider-label {
            display: flex;
            justify-content: space-between;
            font-size: 0.85rem;
            color: #70738c;
            margin-bottom: 10px;
            font-family: monospace;
        }

        .mass-slider {
            width: 100%;
            -webkit-appearance: none;
            height: 4px;
            background: rgba(255,255,255,0.1);
            outline: none;
            border-radius: 2px;
        }

            .mass-slider::-webkit-slider-thumb {
                -webkit-appearance: none;
                width: 16px;
                height: 16px;
                border-radius: 50%;
                background: var(--neon-prime);
                cursor: pointer;
                box-shadow: 0 0 10px var(--neon-prime);
            }

        .align-right {
            justify-content: flex-end;
        }

        .align-center {
            justify-content: center;
            text-align: center;
        }

        .scroll-cue {
            position: absolute;
            bottom: 50px;
            left: 10%;
            font-family: monospace;
            font-size: 0.8rem;
            letter-spacing: 2px;
            color: #3d3f54;
        }
    </style>
</head>
<body>

    <div class="scroll-progress-container"><div class="scroll-progress-bar" id="progressBar"></div></div>

    <div class="hud-system">
        MATRIX LAYER // <span>ANOMALY DETECTED</span><br>
        FIELD MASS SCORE // <span id="hudComplexity">100%</span>
    </div>

    <div id="webgl-container"></div>

    <div class="content-layer">

        <section id="hero">
            <div class="hero-text">
                <h1 id="heroTitle">QUANTUM<br>FLUIDITY</h1>
                <p>Volumetric GPU Spline Simulation</p>
            </div>
            <div class="scroll-cue">DRAG MOUSE AT ANY POSITION TO INJECT ENERGY FIELDS</div>
        </section>

        <section id="details" class="align-right">
            <div class="prestige-panel interactive">
                <h2>01 / QUANTUM MASS DENSITY</h2>
                <p>Alter the energetic behavior of the underlying custom Lorenz Attractor mathematical calculation tracks on the GPU instantly.</p>

                <div class="slider-group">
                    <div class="slider-label"><span>FIELD DENSITY RATIO</span><span id="sliderVal">1.0x</span></div>
                    <input type="range" min="0.2" max="3" step="0.1" value="1" class="mass-slider" id="densitySlider" oninput="updateFieldDensity(this.value)">
                </div>

                <button class="prestige-btn" onclick="triggerQuantumFlash()">STIMULATE FIELD LAYER</button>
            </div>
        </section>

        <section id="register" class="align-center">
            <div class="prestige-panel interactive" style="margin: 0 auto; border-color: rgba(189, 0, 255, 0.2);" id="stasisCard">
                <h2>02 / MATRIX CONVERGENCE</h2>
                <p>The vector threads are preparing for atomic structural capture. Hold your pointer <span style="color: var(--neon-prime); font-weight: bold; text-shadow: 0 0 10px var(--neon-prime);">COMPLETELY STATIC</span> to freeze time, or <span style="color: var(--neon-alt); font-weight: bold; text-shadow: 0 0 10px var(--neon-alt);">SHAKE RAPIDLY</span> to disrupt containment.</p>

                <div style="margin: 25px 0; padding: 20px; background: rgba(0,0,0,0.4); border: 1px solid rgba(255,255,255,0.05); border-radius: 12px;">
                    <div style="display: flex; justify-content: space-between; font-size: 0.8rem; color: #70738c; font-family: monospace; margin-bottom: 10px;">
                        <span>STASIS FIELD LOCK</span>
                        <span id="stasisPercent" style="color: var(--neon-prime); font-weight: bold;">0%</span>
                    </div>
                    <div style="width: 100%; height: 6px; background: rgba(255,255,255,0.05); border-radius: 4px; overflow: hidden; border: 1px solid rgba(0,243,255,0.15);">
                        <div id="stasisBar" style="width: 0%; height: 100%; background: linear-gradient(90deg, var(--neon-prime), var(--quantum-purple)); box-shadow: 0 0 10px var(--neon-prime); transition: background 0.3s ease;"></div>
                    </div>
                    <div id="stasisStatus" style="font-size: 0.75rem; font-family: monospace; color: #4b4d61; margin-top: 10px; text-transform: uppercase; text-align: left;">
                        &gt;&gt; System status: Scanning velocity...
                    </div>
                </div>

                <div id="decryptedPayload" style="max-height: 0px; opacity: 0; overflow: hidden; transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1); font-family: monospace; font-size: 0.85rem; text-align: left; border-top: 1px dashed rgba(0, 255, 102, 0.3); padding-top: 0px;">
                    <div style="color: #00ff66; margin-bottom: 5px;">[SUCCESS] QUANTUM ANOMALY ISOLATED SPEC_KEY // 2026_ALPHA</div>
                    
                </div>
            </div>
        </section>

    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <script id="vertexShader" type="x-shader/x-vertex">
        uniform float uTime;
        uniform float uScrollProgress;
        uniform float uDensityModifier;
        uniform vec2 uMouse;
        varying vec3 vColor;

        void main() {
            vColor = color;
            vec3 pos = position;

            // Phase 1: High Velocity Fluid Wave Calculation
            float fluidWaveX = sin(pos.y * 3.5 + uTime * 2.5) * 0.4;
            float fluidWaveY = cos(pos.x * 3.5 + uTime * 2.0) * 0.4;

            vec3 phase1Pos = pos;
            phase1Pos.x += fluidWaveX;
            phase1Pos.y += fluidWaveY;
            phase1Pos.z += sin(pos.x * pos.y + uTime) * 0.3;

            // Phase 2: Chaotic Spline Lorenz Attractor Configuration
            float loopFactor = pos.z * 15.0;
            vec3 phase2Pos;
            phase2Pos.x = sin(loopFactor + uTime * 0.8) * (1.6 + sin(uTime * 0.5) * 0.3);
            phase2Pos.y = cos(loopFactor * 1.5 + uTime * 1.1) * (1.6 + cos(uTime * 0.4) * 0.3);
            phase2Pos.z = cos(loopFactor * 2.2 + uTime) * 1.2;

            vec3 blendedPos = mix(phase1Pos, phase2Pos, uScrollProgress);

            // Vector Disruption Engine Field Map
            float distanceToCursor = distance(blendedPos.xy, uMouse * 4.0);
            if(distanceToCursor < 1.6) {
                float magneticPull = (1.6 - distanceToCursor) * 0.55 * uDensityModifier;
                blendedPos.x += sin(uTime * 5.0) * magneticPull;
                blendedPos.y += cos(uTime * 5.0) * magneticPull;
                blendedPos.z += magneticPull * 0.5;
            }

            vec4 mvPosition = modelViewMatrix * vec4(blendedPos, 1.0);
            gl_PointSize = (14.0 / -mvPosition.z) * (1.0 + (1.6 - min(distanceToCursor, 1.6)) * 0.5);
            gl_Position = projectionMatrix * mvPosition;
        }
    </script>

    <script id="fragmentShader" type="x-shader/x-fragment">
        varying vec3 vColor;
        void main() {
            vec2 centerCoords = 2.0 * gl_PointCoord - 1.0;
            if (dot(centerCoords, centerCoords) > 1.0) discard;
            float lightGlow = pow(1.0 - dot(centerCoords, centerCoords), 2.5);
            gl_FragColor = vec4(vColor * 2.2, lightGlow * 0.95);
        }
    </script>

    <script>
        // --- 1. SETUP GRAPHICS COMPILING ENGINE ---
        const container = document.getElementById('webgl-container');
        const scene = new THREE.Scene();
        const camera = new THREE.PerspectiveCamera(54, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.z = 4.5;

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
        container.appendChild(renderer.domElement);

        // --- 2. INSTANTIATE HIGH MASS FLUID SPLINE RIBBONS ---
        const particleCount = 28000;
        const geometry = new THREE.BufferGeometry();
        const basePositions = new Float32Array(particleCount * 3);
        const colors = new Float32Array(particleCount * 3);

        const primeColorHex = new THREE.Color('#00f3ff');
        const altColorHex = new THREE.Color('#ff0055');
        const middlePurpleHex = new THREE.Color('#bd00ff');

        for (let i = 0; i < particleCount; i++) {
            const i3 = i * 3;

            const theta = Math.random() * Math.PI * 2.0;
            const radiusSpread = Math.pow(Math.random(), 0.8) * 2.2 + 0.1;

            basePositions[i3] = Math.cos(theta) * radiusSpread;
            basePositions[i3 + 1] = Math.sin(theta) * radiusSpread;
            basePositions[i3 + 2] = (Math.random() - 0.5) * 2.0;

            let finalSelectionColor;
            const colorRnd = Math.random();
            if (colorRnd < 0.35) {
                finalSelectionColor = primeColorHex.clone().lerp(middlePurpleHex, Math.random());
            } else {
                finalSelectionColor = middlePurpleHex.clone().lerp(altColorHex, Math.random());
            }

            colors[i3] = finalSelectionColor.r;
            colors[i3 + 1] = finalSelectionColor.g;
            colors[i3 + 2] = finalSelectionColor.b;
        }

        geometry.setAttribute('position', new THREE.BufferAttribute(basePositions, 3));
        geometry.setAttribute('color', new THREE.BufferAttribute(colors, 3));

        // --- 3. BIND INTERACTIVE GPU SHADERS LAYER ---
        const customMaterial = new THREE.ShaderMaterial({
            uniforms: {
                uTime: { value: 0 },
                uScrollProgress: { value: 0 },
                uDensityModifier: { value: 1.0 },
                uMouse: { value: new THREE.Vector2(0, 0) }
            },
            vertexShader: document.getElementById('vertexShader').textContent,
            fragmentShader: document.getElementById('fragmentShader').textContent,
            transparent: true,
            blending: THREE.AdditiveBlending,
            depthWrite: false,
            vertexColors: true
        });

        const anomalousSystemField = new THREE.Points(geometry, customMaterial);
        scene.add(anomalousSystemField);

        // --- 4. FLUID MOUSE POINTER TRACKING & STASIS METRICS ---
        const targetMouse = new THREE.Vector2(0, 0);
        let stasisCharge = 0;
        let lastMouseX = 0;
        let lastMouseY = 0;
        let mouseVelocity = 0;
        let isStasisComplete = false;
        let absoluteTimeCounter = 0;

        window.addEventListener('mousemove', (event) => {
            targetMouse.x = (event.clientX / window.innerWidth) * 2 - 1;
            targetMouse.y = -(event.clientY / window.innerHeight) * 2 + 1;

            let currentX = targetMouse.x;
            let currentY = targetMouse.y;
            mouseVelocity = Math.sqrt(Math.pow(currentX - lastMouseX, 2) + Math.pow(currentY - lastMouseY, 2));
            lastMouseX = currentX;
            lastMouseY = currentY;
        });

        // --- 5. AUTOMATED GSAP TIMELINE SCROLL SCENOGRAPHY ---
        gsap.registerPlugin(ScrollTrigger);

        gsap.to("#progressBar", {
            width: "100%", ease: "none",
            scrollTrigger: { trigger: ".content-layer", start: "top top", end: "bottom bottom", scrub: true }
        });

        const globalTimeline = gsap.timeline({
            scrollTrigger: {
                trigger: ".content-layer", start: "top top", end: "bottom bottom", scrub: 1.4
            }
        });

        globalTimeline.to(customMaterial.uniforms.uScrollProgress, { value: 1.0, ease: "power2.inOut" }, 0)
            .to(anomalousSystemField.rotation, { x: Math.PI * 0.8, y: Math.PI * 1.2, z: Math.PI * 0.4 }, 0)
            .to("#heroTitle", { opacity: 0, scale: 0.9, y: -30, filter: "blur(10px)" }, 0)
            .to(camera.position, { z: 3.5, y: -0.2, ease: "power1.inOut" }, 0.5);

        // --- 6. FIELD MODIFIER INTERACTION METHODS ---
        window.updateFieldDensity = (val) => {
            document.getElementById('sliderVal').innerText = val + "x";
            document.getElementById('hudComplexity').innerText = Math.floor(val * 100) + "%";
            gsap.to(customMaterial.uniforms.uDensityModifier, { value: val, duration: 0.4 });
        };

        window.triggerQuantumFlash = () => {
            let flashTimeline = gsap.timeline();
            flashTimeline.to(customMaterial.uniforms.uDensityModifier, { value: 6.0, duration: 0.3, ease: "power4.out" })
                .to(anomalousSystemField.rotation, { z: anomalousSystemField.rotation.z + 2.0, duration: 0.6, ease: "expo.out" }, 0)
                .to(customMaterial.uniforms.uDensityModifier, { value: document.getElementById('densitySlider').value, duration: 1.2, ease: "power2.out" });
        };

        // --- 7. HARDWARE PERFORMANCE RENDERING TICK SCHEDULER LOOP ---
        const coreOperationalClock = new THREE.Clock();

        const processFrameRenderPass = () => {
            requestAnimationFrame(processFrameRenderPass);

            const deltaFrameTime = coreOperationalClock.getDelta();
            const currentScrollPosition = customMaterial.uniforms.uScrollProgress.value;

            if (currentScrollPosition > 0.85) {
                if (!isStasisComplete) {
                    // Holding state calculation
                    if (mouseVelocity < 0.005) {
                        stasisCharge = Math.min(stasisCharge + 0.65, 100);
                    } else {
                        stasisCharge = Math.max(stasisCharge - 1.5, 0);
                    }

                    document.getElementById('stasisPercent').innerText = Math.floor(stasisCharge) + "%";
                    document.getElementById('stasisBar').style.width = stasisCharge + "%";

                    if (stasisCharge > 0) {
                        document.getElementById('stasisStatus').innerText = `>> LOCKING MATRIX: CALIBRATING FIELDS (${Math.floor(stasisCharge)}%)`;
                        document.getElementById('stasisStatus').style.color = "var(--neon-prime)";
                    } else {
                        document.getElementById('stasisStatus').innerText = ">> System status: Scanning velocity...";
                        document.getElementById('stasisStatus').style.color = "#4b4d61";
                    }

                    if (stasisCharge === 100) {
                        isStasisComplete = true;
                        document.getElementById('stasisStatus').innerText = ">> CAPTURE MATRIX ATTACHED PROTOCOL STATUS: ONLINE";
                        document.getElementById('stasisStatus').style.color = "#00ff66";
                        document.getElementById('stasisCard').style.borderColor = "#00ff66";
                        document.getElementById('stasisBar').style.background = "#00ff66";

                        const payload = document.getElementById('decryptedPayload');
                        payload.style.maxHeight = "120px";
                        payload.style.opacity = "1";
                        payload.style.paddingTop = "15px";

                        gsap.to(camera.position, { z: 2.2, duration: 2.5, ease: "expo.out" });
                    }
                } else {
                    // STASIS RELEASE DISRUPTION SYSTEM:
                    // If locked, watch for a dramatic spikes in cursor velocity to shatter the field
                    if (mouseVelocity > 0.06) {
                        isStasisComplete = false;
                        stasisCharge = 0; // Reset progress back to baseline

                        // Flash UI alerting user to core disruption status
                        document.getElementById('stasisPercent').innerText = "0%";
                        document.getElementById('stasisBar').style.width = "0%";
                        document.getElementById('stasisBar').style.background = "linear-gradient(90deg, var(--neon-prime), var(--quantum-purple))";
                        document.getElementById('stasisStatus').innerText = ">> WARNING: STASIS FIELD DISRUPTED KINETICALLY";
                        document.getElementById('stasisStatus').style.color = "var(--neon-alt)";
                        document.getElementById('stasisCard').style.borderColor = "var(--neon-alt)";

                        // Fast UI accordion hide animation pass
                        const payload = document.getElementById('decryptedPayload');
                        payload.style.maxHeight = "0px";
                        payload.style.opacity = "0";
                        payload.style.paddingTop = "0px";

                        // Visual zoom out pop animation
                        gsap.to(camera.position, { z: 3.5, duration: 1.2, ease: "power3.out" });

                        // Push sudden explosion kinetic ripple force directly into custom shader arrays
                        let breakdownTimeline = gsap.timeline();
                        breakdownTimeline.to(customMaterial.uniforms.uDensityModifier, { value: 4.0, duration: 0.2 })
                            .to(customMaterial.uniforms.uDensityModifier, { value: document.getElementById('densitySlider').value, duration: 1.5, ease: "power2.out" });
                    }
                }
            }

            // TIME DILATION COMPUTATION: Scale speed factor via active real-time stasis calculation index values
            const currentSpeedDampingMultiplier = 1.0 - (stasisCharge / 100) * 0.98;
            absoluteTimeCounter += deltaFrameTime * currentSpeedDampingMultiplier;

            customMaterial.uniforms.uTime.value = absoluteTimeCounter;

            anomalousSystemField.rotation.y += 0.001 * currentSpeedDampingMultiplier;
            anomalousSystemField.rotation.x += 0.0004 * currentSpeedDampingMultiplier;

            customMaterial.uniforms.uMouse.value.x += (targetMouse.x - customMaterial.uniforms.uMouse.value.x) * 0.06;
            customMaterial.uniforms.uMouse.value.y += (targetMouse.y - customMaterial.uniforms.uMouse.value.y) * 0.06;

            mouseVelocity *= 0.92;

            renderer.render(scene, camera);
        };

        processFrameRenderPass();

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    </script>
</body>
</html>
